import { createStackClient } from "@btst/stack/client"
import { QueryClient } from "@tanstack/react-query"
{{#if clientImports}}
{{{clientImports}}}
{{/if}}

const stackClients = new WeakMap<QueryClient, ReturnType<typeof createStackClient>>()
{{#if clientEntries}}
const getBaseURL = () =>
	typeof window !== "undefined"
		? window.location.origin
		: (process.env.BTST_BASE_URL ??
			import.meta.env.VITE_BASE_URL ??
			"http://localhost:3000")
{{/if}}

export function getStackClient(queryClient: QueryClient) {
	const cached = stackClients.get(queryClient)
	if (cached) return cached
{{#if clientEntries}}
	const baseURL = getBaseURL()
{{/if}}
	const stackClient = createStackClient({
		plugins: {
{{#if clientEntries}}
{{{clientEntries}}}
{{else}}
			// Add client plugins here.
{{/if}}
		},
	})
	stackClients.set(queryClient, stackClient)
	return stackClient
}
