    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "@btst/stack": "workspace:*",
    "@btst/adapter-memory": "^2.1.1",
